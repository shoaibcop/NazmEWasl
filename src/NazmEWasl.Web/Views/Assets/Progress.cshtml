@model NazmEWasl.Web.Models.Domain.Song
@{
    ViewData["Title"] = $"Generating Assets — {Model.Title}";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1>Generating Assets</h1>
        <p class="text-muted">@Model.Title &mdash; @Model.Artist</p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <p id="status-message" class="mb-3 text-muted">Queued, starting soon...</p>

        <div class="progress mb-3" style="height: 28px;">
            <div id="progress-bar"
                 class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                 role="progressbar"
                 style="width: 5%;"
                 aria-valuenow="5" aria-valuemin="0" aria-valuemax="100">
                5%
            </div>
        </div>

        <div id="error-alert" class="alert alert-danger d-none"></div>

        <div id="steps" class="list-group mb-3">
            <div id="step-cards" class="list-group-item d-flex justify-content-between align-items-center">
                <span>Render verse cards</span>
                <span id="step-cards-badge" class="badge bg-secondary">Pending</span>
            </div>
            <div id="step-video" class="list-group-item d-flex justify-content-between align-items-center">
                <span>Assemble video</span>
                <span id="step-video-badge" class="badge bg-secondary">Pending</span>
            </div>
        </div>

        <!-- Cancel button — Feature 2 -->
        <form id="cancel-form" asp-controller="Assets" asp-action="Cancel" asp-route-songId="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="button" id="cancel-btn" class="btn btn-outline-danger btn-sm"
                    onclick="if(confirm('Cancel the running pipeline?')) document.getElementById('cancel-form').submit()">
                Cancel Generation
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const songId = @Model.Id;
    const statusUrl = `/assets/${songId}/poll-status`;
    const assetsUrl = `/assets/${songId}`;
    let intervalId = null;

    function updateBadge(badgeEl, percent) {
        if (percent >= 60)      { badgeEl.className = 'badge bg-success'; badgeEl.textContent = 'Done'; }
        else if (percent >= 35) { badgeEl.className = 'badge bg-info text-dark'; badgeEl.textContent = 'Running'; }
    }

    function poll() {
        fetch(statusUrl)
            .then(r => r.json())
            .then(data => {
                const bar = document.getElementById('progress-bar');
                const msg = document.getElementById('status-message');

                if (data.status === 'failed') {
                    clearInterval(intervalId);
                    bar.classList.remove('progress-bar-animated', 'bg-success');
                    bar.classList.add('bg-danger');
                    bar.style.width = '100%';
                    bar.textContent = 'Failed';
                    msg.textContent = '';
                    const errDiv = document.getElementById('error-alert');
                    errDiv.textContent = data.message || 'Pipeline failed.';
                    errDiv.classList.remove('d-none');
                    document.getElementById('cancel-btn').disabled = true;
                    return;
                }

                if (data.status === 'complete' || data.percent >= 100) {
                    clearInterval(intervalId);
                    window.location.href = assetsUrl;
                    return;
                }

                const pct = Math.max(5, Math.min(data.percent, 99));
                bar.style.width = pct + '%';
                bar.setAttribute('aria-valuenow', pct);
                bar.textContent = pct + '%';
                msg.textContent = data.message || '';

                if (pct >= 35) updateBadge(document.getElementById('step-cards-badge'), pct);
                if (pct >= 80) updateBadge(document.getElementById('step-video-badge'), pct);
            })
            .catch(() => { /* network hiccup — keep polling */ });
    }

    intervalId = setInterval(poll, 2000);
    poll();
})();
</script>
}
