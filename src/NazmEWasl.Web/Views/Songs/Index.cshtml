@model List<NazmEWasl.Web.Models.Domain.Song>
@using NazmEWasl.Web.Models.Domain
@{
    ViewData["Title"] = "Song Library";

    string StatusBadge(SongStatus status) => status switch
    {
        SongStatus.Uploaded         => "bg-secondary",
        SongStatus.Translating      => "bg-warning text-dark",
        SongStatus.AwaitingReview   => "bg-warning text-dark",
        SongStatus.Approved         => "bg-success",
        SongStatus.GeneratingAssets => "bg-info text-dark",
        SongStatus.Complete         => "bg-success",
        _                           => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Song Library</h1>
    <a asp-controller="Songs" asp-action="Create" class="btn btn-primary">+ Add New Song</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No songs yet. <a asp-action="Create">Add your first song.</a></div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Artist</th>
                <th>Verses</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var song in Model)
            {
                <tr>
                    <td>@song.Title</td>
                    <td>@song.Artist</td>
                    <td>@song.Verses.Count</td>
                    <td>
                        <span class="badge @StatusBadge(song.Status)">
                            @if (song.Status == SongStatus.Translating)
                            { <text>&#128336; Translating</text> }
                            else
                            { @song.Status.ToString() }
                        </span>
                    </td>
                    <td>@song.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        <a asp-action="Detail" asp-route-id="@song.Id" class="btn btn-sm btn-outline-primary">Detail</a>
                        @if (song.Status >= SongStatus.AwaitingReview)
                        {
                            <a asp-controller="Translation" asp-action="Review" asp-route-songId="@song.Id" class="btn btn-sm btn-outline-warning ms-1">Review</a>
                        }
                        @if (song.Status == SongStatus.Approved)
                        {
                            <form asp-controller="Assets" asp-action="Generate" asp-route-songId="@song.Id" method="post" class="d-inline ms-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success">Generate</button>
                            </form>
                        }
                        @if (song.Status == SongStatus.GeneratingAssets)
                        {
                            <a asp-controller="Assets" asp-action="Progress" asp-route-songId="@song.Id"
                               class="btn btn-sm btn-outline-info ms-1 disabled">
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>Generating...
                            </a>
                        }
                        @if (song.Status == SongStatus.Complete)
                        {
                            <a asp-controller="Assets" asp-action="Index" asp-route-songId="@song.Id" class="btn btn-sm btn-outline-success ms-1">Assets &#8595;</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
